<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox spacing="15.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="is.vidmot.controller.FerdDialogController"
      prefHeight="300.0" prefWidth="400.0">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <Label text="Heiti ferðar" style="-fx-font-weight: bold;"/>
    <TextField fx:id="nafnField" promptText="Settu inn heiti"/>

    <Label text="Afangastaður" style="-fx-font-weight: bold;"/>
    <TextField fx:id="afangastadurField" promptText="Settu inn afangastaði"/>

    <Label text="Dagsetning" style="-fx-font-weight: bold;"/>
    <TextField fx:id="dagsetningField" promptText="Settu inn dagsetningu"/>

    <HBox spacing="10.0" alignment="CENTER">
        <Button text="Bæta við" onAction="#onBaetaVid"/>
        <Button text="Hætta við" onAction="#onHaettaVid"/>
    </HBox>
</VBox>
