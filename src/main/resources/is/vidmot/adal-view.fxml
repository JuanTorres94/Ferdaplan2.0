<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="10.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="is.vidmot.controller.AdalController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>

    <ListView fx:id="ferdaListView" prefHeight="300.0" prefWidth="400.0" VBox.vgrow="ALWAYS"/>

    <HBox spacing="10.0" alignment="CENTER">
        <Button fx:id="skodaButton" text="Skoða" onAction="#onSkoda"/>
        <Button text="Bæta við" onAction="#onBaetaVid"/>
        <Button fx:id="eydaButton" text="Eyða" onAction="#onEyda"/>
    </HBox>
</VBox>